# Environment variable template for the Django backend.
# Copy to .env and fill in real values. Never commit the actual .env file.

DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=vayuron_db
POSTGRES_USER=vayuron_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend URL (used for Django admin's "View site" link)
FRONTEND_URL=http://localhost:5173

# Email (contact forms, newsletters). Only used in production — development
# uses the console backend (emails print to the runserver terminal instead).
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Vayuron Advanced Systems <no-reply@vayuronadvancedsystems.com>

# File storage
MEDIA_ROOT=/var/www/vayuron/media
STATIC_ROOT=/var/www/vayuron/static
