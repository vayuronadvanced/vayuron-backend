# Environment variable template for the Django backend.
# Copy to .env and fill in real values. Never commit the actual .env file.

DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=vayuron_db
POSTGRES_USER=vayuron_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email (contact forms, newsletters)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# File storage
MEDIA_ROOT=/var/www/vayuron/media
STATIC_ROOT=/var/www/vayuron/static
